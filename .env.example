# --- Backend ---
NODE_ENV=development
PORT=3000
PUBLIC_FRONTEND_URL=http://localhost:5174
PUBLIC_BACKEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://vallentin:vallentin@postgres:5432/vallentin?schema=public

# Auth
JWT_ACCESS_SECRET=replace-me-access
JWT_REFRESH_SECRET=replace-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:3000/api/auth/oauth/google/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URL=http://localhost:3000/api/auth/oauth/facebook/callback

# CAPTCHA (hCaptcha)
HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000

# SMTP (MailHog defaults in dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
MAIL_FROM="Vallentin Claims <no-reply@vallentin.local>"

# Ombudsman
OMBUDSMAN_EMAIL=ombudsman@example.org

# Admin seed
ADMIN_EMAIL=admin@vallentin.local
ADMIN_INITIAL_PASSWORD=ChangeMe!Now1
SEED_DEMO_DATA=true

# Uploads
UPLOAD_DIR=/var/app/uploads
MAX_ATTACHMENTS=3
MAX_ATTACHMENT_TOTAL_BYTES=5242880
MAX_ATTACHMENT_FILE_BYTES=5242880

# Rate limits (per IP per minute unless noted)
RATE_LIMIT_GLOBAL=300
RATE_LIMIT_AUTH=10
RATE_LIMIT_COMPLAINT_SUBMIT=10

# Business config
MIN_BODY_LENGTH=100
SUBMISSION_FORWARD_DEADLINE_SECONDS=30

# --- Frontend (Vite reads VITE_*) ---
VITE_API_BASE_URL=http://localhost:3000/api
VITE_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
VITE_DEFAULT_LOCALE=en
